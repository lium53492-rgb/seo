# Public site configuration
NEXT_PUBLIC_SITE_URL=https://seo-pi-fawn.vercel.app

# Protects /workbench and /api/workbench in production
WORKBENCH_PASSWORD=

# Vercel automatically sends this as a Bearer token to the Cron endpoint
CRON_SECRET=

# AI content generation. Vercel deployments use the automatically injected
# VERCEL_OIDC_TOKEN; set an API key only for non-Vercel runtimes.
SEO_CONTENT_MODEL=openai/gpt-5.5
AI_GATEWAY_API_KEY=

# Keyword intelligence
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
SEMRUSH_COUNTRY=US
SEMRUSH_ROWS_PER_SEED=8
SEO_KEYWORD_SEEDS=voice roleplay,ai roleplay game,ai story game

# Google Search Console (service account is recommended for the daily job)
GSC_SITE_URL=sc-domain:example.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Optional short-lived alternative to the service account pair above
GSC_ACCESS_TOKEN=

# Daily JSON report persistence through the GitHub Contents API
GITHUB_REPORTS_TOKEN=
GITHUB_REPORTS_REPO=lium53492-rgb/seo
GITHUB_REPORTS_BRANCH=main

# Future product funnel adapter
PRODUCT_ANALYTICS_API_URL=
PRODUCT_ANALYTICS_API_TOKEN=
