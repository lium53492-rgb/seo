# Public site configuration
NEXT_PUBLIC_SITE_URL=https://seo-pi-fawn.vercel.app

# Protects /workbench and /api/workbench in production
WORKBENCH_PASSWORD=

# Vercel automatically sends this as a Bearer token to the Cron endpoint
CRON_SECRET=

# Daily production is run by the local Codex research automation. It does not
# require Semrush, a paid keyword API, AI Gateway, or a Google private key.
CODEX_RESEARCH_MODE=true

# Optional: production workbench feedback persistence through GitHub Contents.
# The local automation writes the daily report through Git directly instead.
GITHUB_REPORTS_TOKEN=
GITHUB_REPORTS_REPO=lium53492-rgb/seo
GITHUB_REPORTS_BRANCH=main

# Optional first-party product funnel adapter. Vercel Web Analytics pageviews are
# already instrumented separately through @vercel/analytics.
PRODUCT_ANALYTICS_API_URL=
PRODUCT_ANALYTICS_API_TOKEN=
